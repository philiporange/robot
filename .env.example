# Robot Configuration
# Copy this file to .env and customize as needed

# Web server settings
# Set ROBOT_SERVER_HOST to your server's public IP or hostname for QR code auth links
ROBOT_SERVER_HOST=localhost
ROBOT_SERVER_PORT=9999

# Agent binary paths (optional - uses PATH lookup by default)
# ROBOT_CLAUDE_PATH=/usr/local/bin/claude
# ROBOT_CODEX_PATH=/usr/local/bin/codex
# ROBOT_GEMINI_PATH=/usr/local/bin/gemini
# ROBOT_VIBE_PATH=/usr/local/bin/vibe
# ROBOT_AIDER_PATH=/usr/local/bin/aider

# API keys (optional - uses standard env vars by default)
# ROBOT_CLAUDE_API_KEY=
# ROBOT_CODEX_API_KEY=
# ROBOT_GEMINI_API_KEY=
# ROBOT_VIBE_API_KEY=
# ROBOT_OPENROUTER_API_KEY=

# Defaults
# ROBOT_DEFAULT_AGENT=claude
# ROBOT_DEFAULT_TIMEOUT=180
